#!/bin/bash
set -e

MACHINE_SKILLS_SRC="{{ .chezmoi.homeDir }}/Developer/machine-cfg/skills"
DOTFILES_SKILLS_SRC="{{ .chezmoi.sourceDir }}/skills"
CLAUDE_SKILLS_DST="{{ .chezmoi.homeDir }}/.claude/skills"
CODEX_SKILLS_DST="{{ .chezmoi.homeDir }}/.codex/skills"

# Skip if ~/.claude is still a symlink — migration hasn't happened yet
if [ -L "{{ .chezmoi.homeDir }}/.claude" ]; then
  echo "skills: ~/.claude is still a symlink; run migration steps before skill symlinking will take effect" >&2
  exit 0
fi

# sync_skills <src_dir> <dst_dir>
# Creates symlinks in dst for each skill dir in src; removes stale symlinks
# that originated from this src (won't touch links pointing elsewhere).
sync_skills() {
  local src="$1" dst="$2"
  [ -d "$src" ] || return 0
  mkdir -p "$dst"
  for skill_dir in "$src"/*/; do
    [ -d "$skill_dir" ] || continue
    local skill_name link_path
    skill_name=$(basename "$skill_dir")
    link_path="$dst/$skill_name"
    if [ -L "$link_path" ] && [ "$(readlink "$link_path")" != "$skill_dir" ]; then
      rm "$link_path"
    fi
    if [ ! -e "$link_path" ] && [ ! -L "$link_path" ]; then
      ln -s "$skill_dir" "$link_path"
    fi
  done
  # Only remove links that point into this src (leave links from other sources alone)
  for link in "$dst"/*/; do
    link="${link%/}"
    [ -L "$link" ] || continue
    local target
    target=$(readlink "$link")
    if [[ "$target" == "$src/"* ]] && [ ! -d "$target" ]; then
      rm "$link"
    fi
  done
}

# Populate ~/.claude/skills and ~/.codex/skills from both sources.
# machine-cfg is applied first; dotfiles skills can add to but not override it.
sync_skills "$MACHINE_SKILLS_SRC" "$CLAUDE_SKILLS_DST"
sync_skills "$DOTFILES_SKILLS_SRC" "$CLAUDE_SKILLS_DST"
sync_skills "$MACHINE_SKILLS_SRC" "$CODEX_SKILLS_DST"
sync_skills "$DOTFILES_SKILLS_SRC" "$CODEX_SKILLS_DST"

# Obsidian plugins — link machine-cfg/obsisian/plugins/* into any vault that exists
OBSIDIAN_PLUGINS_SRC="{{ .chezmoi.homeDir }}/Developer/machine-cfg/obsisian/plugins"
if [ -d "$OBSIDIAN_PLUGINS_SRC" ]; then
  for vault in orac daneel; do
    vault_plugins="{{ .chezmoi.homeDir }}/$vault/.obsidian/plugins"
    [ -d "$vault_plugins" ] || continue
    for plugin_dir in "$OBSIDIAN_PLUGINS_SRC"/*/; do
      [ -d "$plugin_dir" ] || continue
      plugin_name=$(basename "$plugin_dir")
      link_path="$vault_plugins/$plugin_name"
      if [ ! -e "$link_path" ] && [ ! -L "$link_path" ]; then
        ln -s "$plugin_dir" "$link_path"
      fi
    done
  done
fi
