#!/bin/bash
set -e

SKILLS_SRC="{{ .chezmoi.homeDir }}/Developer/machine-cfg/claude/skills"
SKILLS_DST="{{ .chezmoi.homeDir }}/.claude/skills"

# Skip if ~/.claude is still a symlink — migration hasn't happened yet
if [ -L "{{ .chezmoi.homeDir }}/.claude" ]; then
  echo "skills: ~/.claude is still a symlink; run migration steps before skill symlinking will take effect" >&2
  exit 0
fi

mkdir -p "$SKILLS_DST"

# Create symlinks for any skill in machine-cfg/skills/ not yet linked
for skill_dir in "$SKILLS_SRC"/*/; do
  [ -d "$skill_dir" ] || continue
  skill_name=$(basename "$skill_dir")
  link_path="$SKILLS_DST/$skill_name"
  if [ ! -e "$link_path" ] && [ ! -L "$link_path" ]; then
    ln -s "$skill_dir" "$link_path"
  fi
done

# Remove stale symlinks for skills removed from machine-cfg/claude/skills/
for link in "$SKILLS_DST"/*/; do
  link="${link%/}"
  [ -L "$link" ] || continue
  skill_name=$(basename "$link")
  if [ ! -d "$SKILLS_SRC/$skill_name" ]; then
    rm "$link"
  fi
done

# Obsidian plugins — link machine-cfg/obsisian/plugins/* into any vault that exists
OBSIDIAN_PLUGINS_SRC="{{ .chezmoi.homeDir }}/Developer/machine-cfg/obsisian/plugins"
if [ -d "$OBSIDIAN_PLUGINS_SRC" ]; then
  for vault in orac daneel; do
    vault_plugins="{{ .chezmoi.homeDir }}/$vault/.obsidian/plugins"
    [ -d "$vault_plugins" ] || continue
    for plugin_dir in "$OBSIDIAN_PLUGINS_SRC"/*/; do
      [ -d "$plugin_dir" ] || continue
      plugin_name=$(basename "$plugin_dir")
      link_path="$vault_plugins/$plugin_name"
      if [ ! -e "$link_path" ] && [ ! -L "$link_path" ]; then
        ln -s "$plugin_dir" "$link_path"
      fi
    done
  done
fi
